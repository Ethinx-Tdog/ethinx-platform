{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Instagram Post Template",
  "description": "Template for generating Instagram-specific social media posts",
  "type": "object",
  "properties": {
    "text": {
      "type": "string",
      "description": "Caption for the Instagram post. Maximum 2,200 characters, but optimal engagement is typically 125-150 characters. First line is most important as it appears before 'more'.",
      "maxLength": 2200
    },
    "cta": {
      "type": "object",
      "description": "Call to action configuration. Note: Instagram feed posts don't support clickable links in captions.",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of CTA action",
          "enum": [
            "link_in_bio",
            "swipe_up",
            "shop_now",
            "dm_us",
            "comment_below",
            "tag_friend",
            "save_post",
            "share_story"
          ]
        },
        "text": {
          "type": "string",
          "description": "CTA text to include in caption",
          "maxLength": 50
        },
        "linkInBioUrl": {
          "type": "string",
          "description": "URL to be placed in bio (for link-in-bio CTAs)",
          "format": "uri"
        }
      },
      "required": ["type", "text"]
    },
    "hashtags": {
      "type": "array",
      "description": "Hashtags for the post. Instagram allows up to 30, but 3-5 strategic hashtags often perform best.",
      "items": {
        "type": "string",
        "pattern": "^#[\\w]+"
      },
      "maxItems": 30
    },
    "imagePrompts": {
      "type": "array",
      "description": "AI image generation prompts for visual content. Instagram is highly visual-focused.",
      "items": {
        "type": "object",
        "properties": {
          "prompt": {
            "type": "string",
            "description": "Detailed prompt for AI image generation"
          },
          "style": {
            "type": "string",
            "description": "Visual style for the generated image",
            "enum": [
              "aesthetic",
              "minimalist",
              "vibrant",
              "moody",
              "bright_airy",
              "editorial",
              "lifestyle",
              "flat_lay",
              "user_generated"
            ]
          },
          "aspectRatio": {
            "type": "string",
            "description": "Image aspect ratio. Instagram supports: 1:1 (feed), 4:5 (portrait), 1.91:1 (landscape)",
            "enum": ["1:1", "4:5", "1.91:1", "9:16"]
          },
          "filter": {
            "type": "string",
            "description": "Suggested Instagram-style filter or color grade",
            "enum": [
              "clarendon",
              "gingham",
              "juno",
              "lark",
              "valencia",
              "warm",
              "cool",
              "none"
            ]
          },
          "altText": {
            "type": "string",
            "description": "Accessibility description for the image",
            "maxLength": 125
          }
        },
        "required": ["prompt"]
      }
    },
    "voiceIntro": {
      "type": "object",
      "description": "Optional voice introduction for Reels or video content",
      "properties": {
        "script": {
          "type": "string",
          "description": "Script text for the voice intro"
        },
        "tone": {
          "type": "string",
          "description": "Desired tone for the voice",
          "enum": [
            "trendy",
            "authentic",
            "energetic",
            "calm",
            "inspirational",
            "humorous",
            "storytelling"
          ]
        },
        "duration": {
          "type": "number",
          "description": "Target duration in seconds. Reels optimal: 15-30 seconds",
          "minimum": 3,
          "maximum": 90
        },
        "backgroundMusic": {
          "type": "string",
          "description": "Suggested background music genre or mood"
        }
      },
      "required": ["script"]
    },
    "metadata": {
      "type": "object",
      "description": "Additional post metadata",
      "properties": {
        "postType": {
          "type": "string",
          "description": "Type of Instagram content",
          "enum": ["feed_post", "carousel", "reel", "story"]
        },
        "location": {
          "type": "string",
          "description": "Location tag for the post"
        },
        "collaborators": {
          "type": "array",
          "description": "Instagram handles for collaboration tags",
          "items": {
            "type": "string",
            "pattern": "^@[\\w.]+"
          }
        },
        "scheduledTime": {
          "type": "string",
          "description": "ISO 8601 datetime for scheduled posting",
          "format": "date-time"
        },
        "campaign": {
          "type": "string",
          "description": "Associated marketing campaign name"
        }
      }
    }
  },
  "required": ["text", "imagePrompts"]
}
