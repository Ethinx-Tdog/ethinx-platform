# SSH Configuration Example for ETHINX Platform
# Copy this file to ~/.ssh/config and customize it for your setup

# GitHub Configuration
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    AddKeysToAgent yes
    UseKeychain yes  # macOS only - stores passphrase in keychain

# GitHub Enterprise (if applicable)
Host github-enterprise.company.com
    HostName github-enterprise.company.com
    User git
    IdentityFile ~/.ssh/id_ed25519
    Port 22

# ETHINX Production Server
Host ethinx-prod
    HostName your-production-server.example.com
    User deploy
    Port 22
    IdentityFile ~/.ssh/ethinx_deploy
    ForwardAgent no
    ServerAliveInterval 60
    ServerAliveCountMax 3
    Compression yes

# ETHINX Staging Server
Host ethinx-staging
    HostName your-staging-server.example.com
    User deploy
    Port 22
    IdentityFile ~/.ssh/ethinx_deploy
    ForwardAgent no
    ServerAliveInterval 60
    ServerAliveCountMax 3
    Compression yes

# ETHINX Development Server
Host ethinx-dev
    HostName your-dev-server.example.com
    User developer
    Port 22
    IdentityFile ~/.ssh/id_ed25519
    ForwardAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

# Redis Server (if remote)
Host redis-server
    HostName your-redis-server.example.com
    User admin
    Port 22
    IdentityFile ~/.ssh/id_ed25519
    LocalForward 6379 localhost:6379
    ServerAliveInterval 60

# Database Server with SSH Tunnel
Host db-server
    HostName your-database-server.example.com
    User dbadmin
    Port 22
    IdentityFile ~/.ssh/id_ed25519
    LocalForward 5432 localhost:5432  # PostgreSQL
    # LocalForward 3306 localhost:3306  # MySQL
    ServerAliveInterval 60

# Default settings for all hosts
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    TCPKeepAlive yes
    ControlMaster auto
    ControlPath ~/.ssh/control-%r@%h:%p
    ControlPersist 300
    # Disable agent forwarding by default for security
    ForwardAgent no
    # Protocol 2 only (SSH v1 is deprecated)
    Protocol 2
    # Disable X11 forwarding if not needed
    ForwardX11 no
    # Use stronger ciphers
    Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
    # Use stronger MACs
    MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
    # Use stronger key exchange algorithms
    KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org,diffie-hellman-group-exchange-sha256
